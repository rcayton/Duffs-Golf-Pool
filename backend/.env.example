# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# The Odds API - https://the-odds-api.com
ODDS_API_KEY=your-odds-api-key

# Odds fetch safety floor — stop fetching when this many tokens remain.
# Free tier has 500/month. 20 is a safe buffer for manual /api/refresh calls.
ODDS_TOKEN_FLOOR=20

# Server
PORT=3001
NODE_ENV=development

# ESPN poll interval in minutes (during active rounds)
POLL_INTERVAL_MINUTES=5
